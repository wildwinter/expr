# Resolve/publish the @wildwinter scope via GitHub Packages (private).
# Auth (a read/write:packages token) lives in the user-level ~/.npmrc locally and
# is injected by actions/setup-node (from NODE_AUTH_TOKEN) in CI - never here, so
# this file is safe to commit and does not shadow a global token for local use.
@wildwinter:registry=https://npm.pkg.github.com
