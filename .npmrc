# Publish/consume the @wildwinter scope via GitHub Packages (private).
# Auth comes from the NODE_AUTH_TOKEN env var (CI: GITHUB_TOKEN; local: a PAT with
# write:packages) - no secret is stored in this file, so it is safe to commit.
@wildwinter:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
