{
  "name": "@wildwinter/expr",
  "version": "0.2.1",
  "description": "Agnostic expression engine: parse, unparse, evaluate, and serialise a small condition/effect expression language. Scopes and built-in functions are injected via a Dialect.",
  "type": "module",
  "license": "MIT",
  "author": "Ian Thomas",
  "repository": { "type": "git", "url": "git+https://github.com/wildwinter/expr.git", "directory": "packages/expr" },
  "keywords": ["expression", "parser", "evaluator", "ast", "dsl", "conditions"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  }
}
